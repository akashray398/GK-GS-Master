<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.akash.gkgsmaster.ui.home.HomeFragment"
        android:label="@string/home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.akash.gkgsmaster.ui.quiz.QuizFragment"
        android:label="@string/quiz"
        tools:layout="@layout/fragment_quiz">
        <argument
            android:name="category"
            app:argType="string" />
        <argument
            android:name="difficulty"
            app:argType="string" />
        <action
            android:id="@+id/action_quizFragment_to_quizResultFragment"
            app:destination="@id/quizResultFragment"
            app:popUpTo="@id/quizFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/quizSetupFragment"
        android:name="com.akash.gkgsmaster.ui.quiz.QuizSetupFragment"
        android:label="Quiz Setup"
        tools:layout="@layout/fragment_quiz_setup">
        <action
            android:id="@+id/action_quizSetupFragment_to_quizFragment"
            app:destination="@id/quizFragment" />
    </fragment>

    <fragment
        android:id="@+id/quizResultFragment"
        android:name="com.akash.gkgsmaster.ui.quiz.QuizResultFragment"
        android:label="Result"
        tools:layout="@layout/fragment_quiz_result">
        <argument
            android:name="result"
            app:argType="com.akash.gkgsmaster.data.model.QuizResult" />
        <action
            android:id="@+id/action_quizResultFragment_to_quizReviewFragment"
            app:destination="@id/quizReviewFragment" />
    </fragment>

    <fragment
        android:id="@+id/quizReviewFragment"
        android:name="com.akash.gkgsmaster.ui.quiz.QuizReviewFragment"
        android:label="Review Answers"
        tools:layout="@layout/fragment_quiz_review" />

    <fragment
        android:id="@+id/learnFragment"
        android:name="com.akash.gkgsmaster.ui.learn.LearnFragment"
        android:label="@string/learn"
        tools:layout="@layout/fragment_learn">
        <action
            android:id="@+id/action_learnFragment_to_GKArticleListFragment"
            app:destination="@id/GKArticleListFragment" />
        <action
            android:id="@+id/action_learnFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookDetailFragment"
        android:name="com.akash.gkgsmaster.ui.learn.BookDetailFragment"
        android:label="Book Detail"
        tools:layout="@layout/fragment_book_detail">
        <argument
            android:name="booklet"
            app:argType="com.akash.gkgsmaster.data.model.Booklet" />
    </fragment>

    <fragment
        android:id="@+id/GKArticleListFragment"
        android:name="com.akash.gkgsmaster.ui.learn.GKArticleListFragment"
        android:label="GK Articles"
        tools:layout="@layout/fragment_gk_article_list">
        <argument
            android:name="categoryId"
            app:argType="string" />
        <argument
            android:name="categoryName"
            app:argType="string" />
        <action
            android:id="@+id/action_GKArticleListFragment_to_GKArticleDetailFragment"
            app:destination="@id/GKArticleDetailFragment" />
        <action
            android:id="@+id/action_GKArticleListFragment_to_learningDetailFragment"
            app:destination="@id/learningDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/learningDetailFragment"
        android:name="com.akash.gkgsmaster.ui.learn.LearningDetailFragment"
        android:label="Topic Detail"
        tools:layout="@layout/fragment_learning_detail">
        <argument
            android:name="topicId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/GKArticleDetailFragment"
        android:name="com.akash.gkgsmaster.ui.learn.GKArticleDetailFragment"
        android:label="Article Detail"
        tools:layout="@layout/fragment_gk_article_detail">
        <argument
            android:name="article"
            app:argType="com.akash.gkgsmaster.data.model.GKArticle" />
    </fragment>

    <fragment
        android:id="@+id/notesFragment"
        android:name="com.akash.gkgsmaster.ui.notes.NotesFragment"
        android:label="@string/notes"
        tools:layout="@layout/fragment_notes">
        <action
            android:id="@+id/action_notesFragment_to_noteDetailFragment"
            app:destination="@id/noteDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/noteDetailFragment"
        android:name="com.akash.gkgsmaster.ui.notes.NoteDetailFragment"
        android:label="Note"
        tools:layout="@layout/fragment_note_detail">
        <argument
            android:name="noteId"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.akash.gkgsmaster.ui.profile.ProfileFragment"
        android:label="@string/profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.akash.gkgsmaster.ui.settings.SettingsFragment"
        android:label="@string/settings"
        tools:layout="@layout/fragment_placeholder" />

    <fragment
        android:id="@+id/scienceFragment"
        android:name="com.akash.gkgsmaster.ui.science.ScienceFragment"
        android:label="General Science"
        tools:layout="@layout/fragment_science">
        <action
            android:id="@+id/action_scienceFragment_to_scienceTopicListFragment"
            app:destination="@id/scienceTopicListFragment" />
    </fragment>

    <fragment
        android:id="@+id/scienceTopicListFragment"
        android:name="com.akash.gkgsmaster.ui.science.ScienceTopicListFragment"
        android:label="Science Topics"
        tools:layout="@layout/fragment_science_topic_list">
        <argument
            android:name="categoryId"
            app:argType="string" />
        <argument
            android:name="categoryName"
            app:argType="string" />
        <action
            android:id="@+id/action_scienceTopicListFragment_to_scienceTopicDetailFragment"
            app:destination="@id/scienceTopicDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/scienceTopicDetailFragment"
        android:name="com.akash.gkgsmaster.ui.science.ScienceDetailFragment"
        android:label="Topic Detail"
        tools:layout="@layout/fragment_science_detail">
        <argument
            android:name="topic"
            app:argType="com.akash.gkgsmaster.data.model.ScienceTopic" />
    </fragment>

    <fragment
        android:id="@+id/bookletListFragment"
        android:name="com.akash.gkgsmaster.ui.booklet.BookletListFragment"
        android:label="Booklets"
        tools:layout="@layout/fragment_booklet_list">
        <action
            android:id="@+id/action_bookletListFragment_to_bookletReaderFragment"
            app:destination="@id/bookletReaderFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookletReaderFragment"
        android:name="com.akash.gkgsmaster.ui.booklet.BookletReaderFragment"
        android:label="Reader"
        tools:layout="@layout/fragment_booklet_reader">
        <argument
            android:name="booklet"
            app:argType="com.akash.gkgsmaster.data.model.Booklet" />
    </fragment>

    <fragment
        android:id="@+id/currentAffairsFragment"
        android:name="com.akash.gkgsmaster.ui.affairs.CurrentAffairsFragment"
        android:label="Current Affairs"
        tools:layout="@layout/fragment_current_affairs" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.akash.gkgsmaster.ui.search.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search">
        <action
            android:id="@+id/action_searchFragment_to_GKArticleListFragment"
            app:destination="@id/GKArticleListFragment" />
        <action
            android:id="@+id/action_searchFragment_to_scienceTopicListFragment"
            app:destination="@id/scienceTopicListFragment" />
    </fragment>

    <fragment
        android:id="@+id/analyticsFragment"
        android:name="com.akash.gkgsmaster.ui.analytics.AnalyticsFragment"
        android:label="Analytics"
        tools:layout="@layout/fragment_analytics" />

    <fragment
        android:id="@+id/adminLoginFragment"
        android:name="com.akash.gkgsmaster.ui.admin.AdminLoginFragment"
        android:label="Admin Login"
        tools:layout="@layout/fragment_admin_login">
        <action
            android:id="@+id/action_adminLoginFragment_to_adminDashboardFragment"
            app:destination="@id/adminDashboardFragment"
            app:popUpTo="@id/adminLoginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/adminDashboardFragment"
        android:name="com.akash.gkgsmaster.ui.admin.AdminDashboardFragment"
        android:label="Admin Dashboard"
        tools:layout="@layout/fragment_admin_dashboard">
        <action
            android:id="@+id/action_adminDashboardFragment_to_adminBookletFragment"
            app:destination="@id/adminBookletFragment" />
        <action
            android:id="@+id/action_adminDashboardFragment_to_adminQuizFragment"
            app:destination="@id/adminQuizFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminBookletFragment"
        android:name="com.akash.gkgsmaster.ui.admin.AdminBookletFragment"
        android:label="Manage Booklets"
        tools:layout="@layout/fragment_admin_booklet">
        <action
            android:id="@+id/action_adminBookletFragment_to_adminAddBookletFragment"
            app:destination="@id/adminAddBookletFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminAddBookletFragment"
        android:name="com.akash.gkgsmaster.ui.admin.AdminAddBookletFragment"
        android:label="Add Booklet"
        tools:layout="@layout/fragment_admin_add_booklet" />

    <fragment
        android:id="@+id/adminQuizFragment"
        android:name="com.akash.gkgsmaster.ui.admin.AdminQuizFragment"
        android:label="Manage Quiz"
        tools:layout="@layout/fragment_admin_quiz">
        <action
            android:id="@+id/action_adminQuizFragment_to_adminAddQuestionFragment"
            app:destination="@id/adminAddQuestionFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminAddQuestionFragment"
        android:name="com.akash.gkgsmaster.ui.admin.AdminAddQuestionFragment"
        android:label="Add Question"
        tools:layout="@layout/fragment_admin_add_question" />

</navigation>
